          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Latest assistant has no ragError" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper
def json = new JsonSlurper().parseText(prev.getResponseDataAsString())
def assistants = json.messages.findAll { it.role == &apos;assistant&apos; }
if (assistants.isEmpty()) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&apos;No assistant message in conversation&apos;)
    return
}
def last = assistants[-1]
if (last.ragError) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&apos;ragError on latest assistant message: &apos; + last.ragError)
}
</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223Assertion>
